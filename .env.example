# --- Copy to .env for local runs (never commit .env) -------------------------
#
# The proxy resolves a Google credential ONCE at startup, in the PRIORITY order
# below. Everything except the legacy static token AUTO-REFRESHES (via
# google-auth-library) so the service keeps working indefinitely with no manual
# re-minting. Set exactly ONE. Leave the rest blank. Never commit real secrets.

# (1) RECOMMENDED — full JSON contents of ANY Google credential file. Every type
#     is accepted and auto-refreshed:
#       authorized_user                    your user ADC (client_id / client_secret /
#                                          refresh_token) — zero admin, works with
#                                          your existing roles/aiplatform.user
#       service_account                    admin-issued SA key JSON
#       external_account                   workload identity federation config
#       external_account_authorized_user   workforce identity (browser-login) config
#       impersonated_service_account       impersonation config
#     Upgrading the credential later is a CONFIG change — paste the new JSON,
#     redeploy, done. Produce your user ADC (login once, then print the file):
#       gcloud auth application-default login
#       Windows PowerShell:
#         Get-Content "$env:APPDATA\gcloud\application_default_credentials.json" -Raw
#       macOS/Linux:
#         cat ~/.config/gcloud/application_default_credentials.json
#     Paste the whole JSON as a single-line SECRET env var value (from { to }).
#     The proxy validates it at startup and FAILS CLOSED (health shows
#     misconfigured:true) if the paste was mangled — it never echoes parse
#     errors (which contain secret fragments) to clients.
#     Security note: user ADC is your BROAD personal credential — keep the
#     secret store locked; revoke with `gcloud auth application-default revoke`.
GOOGLE_ADC_JSON=

# (2) Service-account key JSON — same handling as GOOGLE_ADC_JSON, kept as a
#     separate slot so an admin-issued key can coexist without overwriting (1).
GOOGLE_SA_KEY_JSON=

# (3) Ambient ADC — no value here. Set GOOGLE_APPLICATION_CREDENTIALS to a key
#     file PATH, or deploy on GCP (Cloud Run / GCE) so the metadata server mints
#     tokens for the attached service account. Keyless; no code change needed.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# (0) LEGACY / last-resort — a static ~1h access token. NOT auto-refreshed;
#     expires in ~1 hour ( /api/health reports degraded:true in this mode).
#     Mint with:  gcloud auth application-default print-access-token
GOOGLE_ACCESS_TOKEN=

# Target reasoning engine coordinates.
GCP_PROJECT=ve-grp-1-333-project3-9rqd
GCP_REGION=us-central1
ENGINE_ID=8893446530510356480

# --- Optional hardening (all off/default when unset) --------------------------

# Require the x-council-key header on /api/council and /api/council/stream.
# Set any long random string here AND give it to the SPA's users (the UI asks
# for it once and stores it in the browser). Unset = API is open (local dev).
# COUNCIL_API_KEY=

# Per-IP requests/minute on the council routes (default 10; 0 disables).
# RATE_LIMIT_PER_MIN=10

# Max council runs in flight at once across all clients (default 3).
# MAX_INFLIGHT=3

# Max prompt length in characters (default 4000).
# MAX_PROMPT_CHARS=4000

# Include raw upstream Vertex error bodies in client responses (debug only —
# they can reveal project/IAM details; server logs always capture them).
# DEBUG_UPSTREAM_ERRORS=1

# --- Test / advanced -----------------------------------------------------------

# Override the Vertex endpoint (used by offline tests to point at a mock).
# VERTEX_BASE_URL=http://127.0.0.1:9099

# Agent identifiers used to route the synthesis (defaults match this repo's
# council_moderator workflow — only set if you renamed the agent or node).
# ROOT_AGENT_NAME=council_moderator
# ROOT_NODE_NAME=main_orchestration_workflow

# Upstream stream timeout in ms (default 200000 = 200s).
# UPSTREAM_TIMEOUT_MS=200000

# PORT is injected automatically by Render; only set it locally if you want a
# specific port. The server defaults to 8080 when PORT is unset.
# PORT=8080
