# --- Copy to .env for local runs (never commit .env) -------------------------
#
# The proxy resolves a Google credential ONCE at startup, in the PRIORITY order
# below. The first three AUTO-REFRESH (via google-auth-library) so the POC keeps
# working past ~1 hour with no manual re-minting. Set exactly ONE. Leave the rest
# blank. Never commit real secret values.

# (1) RECOMMENDED — full JSON contents of your user Application Default
#     Credentials (type "authorized_user": client_id / client_secret /
#     refresh_token). Auto-refreshes; works with your existing
#     roles/aiplatform.user — no admin, no service account.
#     Produce it (login once, then print the file as a SINGLE line):
#       gcloud auth application-default login
#       Windows PowerShell:
#         Get-Content "$env:APPDATA\gcloud\application_default_credentials.json" -Raw
#       macOS/Linux:
#         cat ~/.config/gcloud/application_default_credentials.json
#     Paste the whole JSON as a single-line SECRET env var value.
#     Security note: this is your BROAD personal credential — keep the secret
#     store locked; revoke with `gcloud auth application-default revoke`.
GOOGLE_ADC_JSON=

# (2) Service-account key JSON (type "service_account"), if an admin provides
#     one. Auto-refreshes. Paste the whole key JSON as a single-line secret.
GOOGLE_SA_KEY_JSON=

# (3) Ambient ADC — no value here. Set GOOGLE_APPLICATION_CREDENTIALS to a key
#     file PATH, or deploy on GCP (Cloud Run / GCE) so the metadata server mints
#     tokens for the attached service account. Keyless; no code change needed.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# (0) LEGACY / last-resort — a static ~1h access token. NOT auto-refreshed;
#     expires in ~1 hour and must be re-minted on every 401. This was the old
#     bug — prefer (1) above. Mint with:
#       gcloud auth application-default print-access-token
GOOGLE_ACCESS_TOKEN=

# Target reasoning engine coordinates.
GCP_PROJECT=ve-grp-1-333-project3-9rqd
GCP_REGION=us-central1
ENGINE_ID=8893446530510356480

# PORT is injected automatically by Render; only set it locally if you want a
# specific port. The server defaults to 8080 when PORT is unset.
# PORT=8080
